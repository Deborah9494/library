{% extends 'base.html.twig' %}

{% block title %}Books{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">Books</h1>

    <table id="booksTable" class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Title</th>
                <th>ISBN</th>
                <th>Publication Date</th>
            </tr>
        </thead>

        <tbody>
        {% for book in books %}
            
                <tr>
                    <td>
                        <a href="{{ path('book_detail', {id: book.id}) }}">
                            {{ book.bookName }}
                        </a>
                    </td>
                    <td>{{ book.isbn13 }}</td>
                    <td>{{ book.publicationDate|date('Y-m-d') }}</td>
                </tr>
        {% endfor %}
        </tbody>
    </table>

</div>

{% endblock %}
